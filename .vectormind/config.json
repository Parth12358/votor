{
  "main_provider": "ollama",
  "write_mode": "edit",
  "main_model": "qwen2.5:7b",
  "fallback_model": "qwen2.5:14b",
  "sub_provider": "ollama",
  "sub_model": "qwen2.5:7b",
  "embedding_provider": "ollama",
  "embedding_model": "nomic-embed-text",
  "top_k": 5,
  "chunk_size": 200,
  "chunk_overlap": 20,
  "git_remote": "none",
  "git_remote_url": "",
  "extensions": [
    ".py",
    ".js",
    ".ts",
    ".jsx",
    ".tsx",
    ".java",
    ".cpp",
    ".c",
    ".h",
    ".cs",
    ".go",
    ".rs",
    ".rb",
    ".php",
    ".md",
    ".txt",
    ".json",
    ".yaml",
    ".yml",
    ".toml",
    ".env.example"
  ],
  "exclude_dirs": [
    ".vectormind",
    ".git",
    "node_modules",
    "__pycache__",
    ".venv",
    "venv",
    "dist",
    "build",
    ".next"
  ]
}